# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# OpenAI — used for script generation and voiceover
OPENAI_API_KEY=sk-proj-...

# ElevenLabs — used for text-to-speech voiceover
ELEVENLABS_API_KEY=sk_...

# Supabase — used for auth and database
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Runway ML — used for AI video generation
RUNWAY_API_KEY=key_...
