# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# OpenAI — used for script generation and voiceover
OPENAI_API_KEY=sk-proj-...

# ElevenLabs — used for text-to-speech voiceover
ELEVENLABS_API_KEY=sk_...

# Supabase — used for auth and database
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Runway ML — used for AI video generation
RUNWAY_API_KEY=key_...

# Mollie — used for payment processing and subscriptions
MOLLIE_API_KEY=live_...
MOLLIE_WEBHOOK_SECRET=random_string_at_least_32_chars

# App URL — used in Mollie redirect/webhook URLs
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Supabase service role key — used by Mollie webhook to bypass RLS
# Find this in Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...
